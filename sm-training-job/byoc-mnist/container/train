#!/usr/bin/env python
"""SageMaker BYOC 학습 프로그램.

중요: 이 파일 이름은 반드시 'train' 입니다 (확장자 없음).
   SageMaker는 학습을 시작할 때 컨테이너를 이렇게 실행합니다:  docker run <image> train
   즉 PATH 위에 있는 'train' 이라는 실행파일을 그냥 실행합니다. 그래서 hello-mnist(스크립트 모드)와
   달리, SageMaker SDK가 넣어주는 래퍼가 없습니다. /opt/ml 규약을 우리가 직접 다룹니다.

BYOC 학습 컨테이너의 파일시스템 규약 (SageMaker가 만들어 줌):
  /opt/ml/input/config/hyperparameters.json   하이퍼파라미터 (전부 문자열! 캐스팅 필요)
  /opt/ml/input/data/training/                 'training' 입력 채널 (launch.py가 S3에서 주입)
  /opt/ml/model/                               여기에 저장하면 SageMaker가 model.tar.gz로 S3 업로드
  /opt/ml/output/failure                       실패 시 여기에 이유를 적으면 FailureReason으로 보임
"""

import json
import os
import sys
import traceback

import torch
import torch.nn as nn
import torch.nn.functional as F
from torch.utils.data import DataLoader
from torchvision import datasets, transforms

# --- SageMaker BYOC 규약 경로 ---
PREFIX = "/opt/ml"
HP_PATH = os.path.join(PREFIX, "input/config/hyperparameters.json")
DATA_DIR = os.path.join(PREFIX, "input/data/training")  # 'training' 채널이 마운트되는 곳
MODEL_DIR = os.path.join(PREFIX, "model")
FAILURE_PATH = os.path.join(PREFIX, "output/failure")


class Net(nn.Module):
    """간단한 CNN."""

    def __init__(self):
        super().__init__()
        self.conv1 = nn.Conv2d(1, 32, 3, 1)
        self.conv2 = nn.Conv2d(32, 64, 3, 1)
        self.fc1 = nn.Linear(9216, 128)
        self.fc2 = nn.Linear(128, 10)

    def forward(self, x):
        x = F.relu(self.conv1(x))
        x = F.relu(self.conv2(x))
        x = F.max_pool2d(x, 2)
        x = torch.flatten(x, 1)
        x = F.relu(self.fc1(x))
        return self.fc2(x)


def read_hyperparameters():
    """/opt/ml/input/config/hyperparameters.json 을 읽는다.

    값은 전부 '문자열'로 들어옵니다 (예: {"epochs": "3"}). 직접 캐스팅해야 합니다.
    파일이 없을 수도 있으니(하이퍼파라미터 미지정) 기본값을 둡니다.
    """
    hp = {}
    if os.path.exists(HP_PATH):
        with open(HP_PATH) as f:
            hp = json.load(f)
    return {"epochs": int(hp.get("epochs", 3))}


def train():
    hp = read_hyperparameters()
    device = "cuda" if torch.cuda.is_available() else "cpu"
    print(f"device={device} hyperparameters={hp}", flush=True)  # print → CloudWatch Logs

    # 'training' 채널에서 MNIST를 읽습니다 (download=False).
    #   SageMaker가 launch.py에서 지정한 S3 데이터를 /opt/ml/input/data/training/ 에 마운트해 줍니다.
    #   torchvision은 <root>/MNIST/raw/ 에서 원시 파일을 찾으므로, launch.py도 같은 구조로 올립니다.
    tfm = transforms.Compose([transforms.ToTensor(), transforms.Normalize((0.1307,), (0.3081,))])
    train_loader = DataLoader(
        datasets.MNIST(DATA_DIR, train=True, download=False, transform=tfm),
        batch_size=128, shuffle=True,
    )
    test_loader = DataLoader(
        datasets.MNIST(DATA_DIR, train=False, download=False, transform=tfm),
        batch_size=1000,
    )

    model = Net().to(device)
    optimizer = torch.optim.Adam(model.parameters(), lr=1e-3)

    for epoch in range(1, hp["epochs"] + 1):
        model.train()
        for data, target in train_loader:
            data, target = data.to(device), target.to(device)
            optimizer.zero_grad()
            F.cross_entropy(model(data), target).backward()
            optimizer.step()

        model.eval()
        correct = 0
        with torch.no_grad():
            for data, target in test_loader:
                data, target = data.to(device), target.to(device)
                correct += model(data).argmax(1).eq(target).sum().item()
        acc = correct / len(test_loader.dataset)
        print(f"epoch {epoch}: test_accuracy={acc:.4f}", flush=True)

    # /opt/ml/model 에 저장 → SageMaker가 자동으로 model.tar.gz 로 묶어 S3에 업로드
    os.makedirs(MODEL_DIR, exist_ok=True)
    torch.save(model.state_dict(), os.path.join(MODEL_DIR, "model.pth"))
    print("saved model to /opt/ml/model", flush=True)


if __name__ == "__main__":
    try:
        train()
        sys.exit(0)  # 종료코드 0 = 성공(Completed)
    except Exception as e:
        # 실패 이유를 /opt/ml/output/failure 에 적으면 DescribeTrainingJob의 FailureReason으로 보임
        os.makedirs(os.path.dirname(FAILURE_PATH), exist_ok=True)
        with open(FAILURE_PATH, "w") as f:
            f.write(f"Exception during training: {e}\n{traceback.format_exc()}")
        print(f"training failed: {e}", file=sys.stderr, flush=True)
        sys.exit(1)  # 0이 아닌 종료코드 = 실패(Failed)
